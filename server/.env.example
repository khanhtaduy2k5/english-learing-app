# Example .env for connecting to Supabase (DO NOT COMMIT real credentials)
# Replace placeholders with your Supabase project values.

# Supabase client (optional, used by frontend if exposing public keys)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key

# Server-side JDBC URL for Spring Boot (use sslmode=require for Supabase)
# Format: jdbc:postgresql://<host>:5432/<database>?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://<your-project>.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=<db_user>
SPRING_DATASOURCE_PASSWORD=<db_password>

# Optional: if you prefer DATABASE_URL format
# DATABASE_URL=postgres://<user>:<password>@<host>:5432/postgres
